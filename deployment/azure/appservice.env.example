# Azure App Service settings. Replace placeholders in the Azure portal.
SCM_DO_BUILD_DURING_DEPLOYMENT=1
FRESHSENSE_AUTH_MODE=entra
FRESHSENSE_ENTRA_TENANT_ID=<external-id-tenant-id>
FRESHSENSE_ENTRA_API_CLIENT_ID=<freshsense-api-client-id>
FRESHSENSE_ENTRA_AUTHORITY=https://freshsenseai.ciamlogin.com/<external-id-tenant-id>
FRESHSENSE_ENTRA_REQUIRED_SCOPE=access_as_user
FRESHSENSE_ENTRA_ALLOWED_CLIENT_IDS=<freshsense-spa-client-id>
FRESHSENSE_CORS_ORIGINS=https://<freshsense-web>.azurestaticapps.net
FRESHSENSE_ALLOWED_HOSTS=<freshsense-api>.azurewebsites.net
FRESHSENSE_SAAS_DATABASE_URL=postgresql+psycopg://<user>:<urlencoded-password>@<server>.postgres.database.azure.com:5432/freshsense?sslmode=verify-full
FRESHSENSE_RUNTIME_BUNDLE_URL=https://<approved-artifact-location>/runtime-bundle.zip
FRESHSENSE_RUNTIME_BUNDLE_SHA256=<lowercase-64-character-sha256>
FRESHSENSE_JSON_LOGS=true
FRESHSENSE_REQUIRE_OPEN_SET_GATE=true
FRESHSENSE_REQUIRE_SEMANTIC_RAG=true
FRESHSENSE_EMBEDDING_LOCAL_ONLY=true
FRESHSENSE_API_RATE_LIMIT_PER_MINUTE=30
